<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meu Feed Interativo</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header>
        <h1>Galeria Interativa</h1>
    </header>

    <main class="feed">
        <div class="card">
            <img src="https://picsum.photos/400/300?random=1" alt="Imagem Linda 1" class="card-img">
            <div class="card-content">
                <h3>Aventura na Natureza</h3>
                <p>Explore o mundo e descubra paisagens incríveis.</p>
                <div class="interactions">
                    <button class="like-btn">❤️ Curtir (<span class="like-count">0</span>)</button>
                </div>
            </div>
        </div>

        <div class="card">
            <img src="https://picsum.photos/400/300?random=2" alt="Imagem Linda 2" class="card-img">
            <div class="card-content">
                <h3>Luzes da Cidade</h3>
                <p>A energia urbana que nunca dorme durante a noite.</p>
                <div class="interactions">
                    <button class="like-btn">❤️ Curtir (<span class="like-count">0</span>)</button>
                </div>
            </div>
        </div>
    </main>

    <script src="script.js"></script>
</body>
</html>/* Reset básico para zerar margens padrão */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

body {
    background-color: #f0f2f5;
    color: #333;
    padding: 20px;
}

header {
    text-align: center;
    margin-bottom: 30px;
}

/* Container dos cards */
.feed {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 25px; /* Espaçamento entre os cards */
}

/* Estrutura do Card */
.card {
    background-color: #fff;
    border-radius: 12px;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    max-width: 400px;
    width: 100%;
    overflow: hidden; /* Garante que a imagem respeite as bordas arredondadas */
    transition: transform 0.2s;
}

.card:hover {
    transform: translateY(-5px); /* Efeito sutil ao passar o mouse */
}

/* Estilização da Imagem */
.card-img {
    width: 100%;
    height: 250px;
    object-fit: cover; /* Faz a imagem preencher o espaço sem distorcer */
}

/* Espaçamentos internos do texto */
.card-content {
    padding: 20px;
}

.card-content h3 {
    margin-bottom: 10px;
}

.card-content p {
    color: #666;
    margin-bottom: 15px;
    line-height: 1.4;
}

/* Botão de Curtir */
.like-btn {
    background-color: #e4e6eb;
    border: none;
    padding: 10px 15px;
    border-radius: 20px;
    font-weight: bold;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
}

/* Classe que o JavaScript vai adicionar ao curtir */
.like-btn.liked {
    background-color: #ff4757;
    color: white;
}// 1. Seleciona todos os botões de curtir da página
const botoesCurtir = document.querySelectorAll('.like-btn');

// 2. Passa por cada botão usando o forEach (para múltiplos elementos)
botoesCurtir.forEach((botao) => {
    
    // Variável interna para controlar se ESSE botão específico foi curtido
    let curtido = false;
    
    // Seleciona o número do contador que está dentro DESSE botão específico
    const contadorTexto = botao.querySelector('.like-count');

    // 3. Adiciona o evento de clique para o botão atual
    botao.addEventListener('click', () => {
        // Pega o número atual de curtidas e transforma em número inteiro
        let curtidasAtuais = parseInt(contadorTexto.textContent);

        if (!curtido) {
            // Lógica para CURTIR
            curtidasAtuais++;
            botao.classList.add('liked'); // Muda a cor para vermelho via CSS
            curtido = true;
        } else {
            // Lógica para DESCURTIR
            curtidasAtuais--;
            botao.classList.remove('liked'); // Volta para a cor padrão
            curtido = false;
        }

        // Atualiza o texto do contador na tela
        contadorTexto.textContent = curtidasAtuais;
    });
});